{
	"$schema": "https://ui.shadcn.com/schema.json",
	"style": "radix-lyra",
	"rsc": true,
	"tsx": true,
	"tailwind": {
		"css": "src/app/globals.css",
		"baseColor": "olive",
		"cssVariables": true,
		"prefix": ""
	},
	"iconLibrary": "lucide-icons",
	"rtl": false,
