{
	"$schema": "https://biomejs.dev/schemas/2.3.13/schema.json",
	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
	"files": { "ignoreUnknown": false, "includes": ["**", "!.next", "!.pnpm-store", "!node_modules"] },
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [[":NODE:"], ":BLANK_LINE:", [":PACKAGE:", "!@/**"], ":BLANK_LINE:", ["@/**"], [":PATH:"]]
					}
				}
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"nursery": {
				"useSortedClasses": {
					"level": "error",
					"fix": "safe",
					"options": {
						"attributes": ["className"],
						"functions": ["clsx", "cva", "cn"]
					}
				}
			}
		}
	},
	"overrides": [
		{
			"includes": ["src/app/globals.css"],
			"css": {
				"linter": {
					"enabled": false
				}
			}
		}
	],
	"formatter": {
		"enabled": true,
		"lineWidth": 120,
		"bracketSpacing": true
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
